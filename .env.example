# Local development values. Copy this file to .dev.vars (loaded by wrangler dev).
# Do not commit real credentials.

# HTTP Basic Auth credential for the API (the only supported auth).
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASS="change-me"

# Optional Cloudflare CLI auth for deploys, if not using `wrangler login`.
# CLOUDFLARE_API_TOKEN="<token>"
# CLOUDFLARE_ACCOUNT_ID="<account-id>"
